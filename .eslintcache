ddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span\r\n                className=\"home-text font-heading-white\"\r\n                style={{ lineHeight: \"20px\" }}\r\n              >\r\n                <T>how_it_works.choose</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <ArrowRightOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.8rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span\r\n                className=\"home-text font-heading-white\"\r\n                style={{ lineHeight: \"20px\" }}\r\n              >\r\n                <T>how_it_works.gt</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <ArrowRightOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.8rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span\r\n                className=\"home-text font-heading-white\"\r\n                style={{ lineHeight: \"20px\" }}\r\n              >\r\n                <T>how_it_works.ad</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <ArrowRightOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.8rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span\r\n                className=\"home-text font-heading-white\"\r\n                style={{ lineHeight: \"20px\" }}\r\n              >\r\n                <T>how_it_works.start_over</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n 