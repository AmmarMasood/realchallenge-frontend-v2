          paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span className=\"home-text font-paragraph-white\">\r\n                <T>home.home-row-5.all_the_tools</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <CheckOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.5rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span className=\"home-text font-paragraph-white\">\r\n                <T>home.home-row-5.daily_updates</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <CheckOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.5rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span className=\"home-text font-paragraph-white\">\r\n                <T>home.home-row-5.your_personal</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <CheckOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.5rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span className=\"home-text font-paragraph-white\">\r\n                <T>home.home-row-5.choose</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <CheckOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.5rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span className=\"home-text font-paragraph-white\">\r\n                <T>home.home-row-5.week</T>\r\n              </span>\r\n            </div>\r\n            <div className=\"home-row-2-col-2-box\">\r\n              <CheckOutlined\r\n                style={{\r\n                  color: \"#ff7700\",\r\n                  fontSize: \"2.5rem\",\r\n                  paddingRight: \"0.5rem\",\r\n                }}\r\n              />\r\n              <span className=\"home-text font-paragraph-white\">\r\n                <T>home.home-row-5.comm</T>\r\n              </span>\r\n            </div>\r\n\r\n            <div style={{ paddingTop: \"20px\" }}>\r\n              <Link className=\"home-button\" to=\"/new\">\r\n                <span className=\"home-button-text\">\r\n                  <T>common.free_intake</T> <ArrowRightOutlined />\r\n                </span>\r\n              </Link>\r\n              <Link\r\n                className=\"home-button-2\"\r\n                to=\"/how-it-works\"\r\n                style={{ marginLeft: \"10px\" }}\r\n              >\r\n                <span className=\"home-button-text\">\r\n                  <T>common.how_it_works</T>\r\n                </span>\r\n              </Link>\r\n            </div>\r\n          </div>\r\n          <div className=\"home-row-5-column-2\">\r\n            <img\r\n              src={MobileScreen}\r\n              alt=\"mobile-screen\"\r\n              className=\"home-row-5-column-2-image\"\r\n            />\r\n          </div>\r\n        </div>\r\n      </div>\r\n      {/* 5th row */}\r\n      {/* 6th row */}\r\n      <div className=\"home-row-6\">\r\n        <h1 className=\"home-row-6-heading font-heading-black\">\r\n          <T>home.home-row-6.we_share_exp</T>\r\n        </h1>\r\n        <p style={{ fontSize: \"18px\" }} className=\"font-paragraph-black\">\r\n          <T>home.home-row-6.this_is</T>\r\n        </p>\r\n        <div className=\"home-row-6-video-container\">\r\n          <div\r\n            className=\"home-row-6-video-container-box home-6-box-1\"\r\n            style={{ textAlign: \"left\" }}\r\n            onClick={() => {\r\n              setLink(\"https://www.youtube.com/embed/jVfuTFgUQEo\");\r\n              setOpen(true);\r\n            }}\r\n          >\r\n            <div className=\"pricing-video-box-overlay\"></div>\r\n            <div className=\"home-row-6-text font-paragraph-white\">\r\n              <PlayCircleOutlined className=\"play-icon\" />{\" \"}\r\n              <T>home.home-row-6.find_the_right</T>\r\n            </div>\r\n          </div>\r\n          <div\r\n            className=\"home-row-6-video-container-box home-6-box-2\"\r\n            style={{ textAlign: \"left\" }}\r\n            onClick={() => {\r\n              setLink(\"https://youtu.be/dakFOeZGbO4\");\r\n              setOpen(true);\r\n            }}\r\n          >\r\n            <div className=\"pricing-video-box-overlay\"></div>\r\n            <div className=\"home-row-6-text font-paragraph-white\">\r\n              <PlayCircleOutlined className=\"play-icon\" />{\" \"}\r\n              <T>home.home-row-6.customized_plan</T>\r\n            </div>\r\n          </div>\r\n          <div\r\n            className=\"home-row-6-video-container-box home-6-box-3\"\r\n            onClick={() => {\r\n              setLink(\"https://youtu.be/0e_0sSkH_dQ\");\r\n              setOpen(true);\r\n            }}\r\n            style={{ textAlign: \"left\" }}\r\n          >\r\n            <div className=\"pricing-video-box-overlay\"></div>\r\n            <div className=\"home-row-6-text font-paragraph-white\">\r\n              <PlayCircleOutlined className=\"play-icon\" />{\" \"}\r\n              <T>home.home-row-6.exercise_whenever</T>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      {/* 6th row */}\r\n      {/* 7th row */}\r\n      <div className=\"home-row-7\">\r\n        <div className=\"home-row-7-container\">\r\n          <div className=\"home-row-7-container-text\">\r\n            <h2 style={{ fontSize: \"2rem\" }} className=\"font-subheading-black\">\r\n              <T>home.home-row-7.quit</T>\r\n            </h2>\r\n            <h1 style={{ fontSize: \"4.5rem\" }} className=\"font-heading-black\">\r\n              <T>home.home-row-7.feel</T>\r\n            </h1>\r\n            <p\r\n              style={{ fontSize: \"1.8rem\", paddingBottom: \"10px\" }}\r\n              className=\"font-paragraph-black\"\r\n            >\r\n              <T>home.homeTrow-7.together</T>\r\n            </p>\r\n            <Link className=\"home-button\" to=\"/challenges\">\r\n              <span className=\"home-button-text font-paragraph-white\">\r\n                <T>common.start_your_challenge_today</T> <ArrowRightOutlined />\r\n              </span>\r\n            </Link>\r\n            <p style={{ paddingTop: \"10px\" }} className=\"font-paragraph-black\">\r\n              <T>common.price</T>{\" \"}\r\n              <Link to=\"/how-it-works\" style={{ color: \"#ff7700\" }}>\r\n                <T>common.how_it_works_small</T>\r\n              </Link>\r\n            </p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      {/* 7th row */}\r\n      {/* 8th row */}\r\n      <div className=\"home-row-6\" style={{ padding: \"100px 50px\" }}>\r\n        {console.log(allBlogs, \"here\")};\r\n        <h1 className=\"home-row-6-heading font-heading-black\">\r\n          <T>home.home-row-8.how</T>\r\n        </h1>\r\n        <p style={{ fontSize: \"18px\" }} className=\"font-paragraph-black\">\r\n          <T>home.home-row-8.be_sure</T>\r\n        </p>\r\n        <div className=\"home-row-6-video-container\">\r\n          {allBlogs.map(\r\n            (blog, i) =>\r\n              blog.adminApproved &&\r\n              blog.isPublic && (\r\n                <Link\r\n                  key={i}\r\n                  to={`/magazine/${slug(blog.title)}/${blog._id}`}\r\n                  style={{\r\n                    textAlign: \"left\",\r\n                    cursor: \"pointer\",\r\n                    color: \"#171e27\",\r\n                    padding: \"10px\",\r\n                    width: \"100%\",\r\n                  }}\r\n                >\r\n                  <div\r\n                    className=\"magazine-row-2-box\"\r\n                    style={{ height: \"300px\" }}\r\n                  >\r\n                    <div\r\n                      className=\"home-row-8-blog-container-box home-8-box-1\"\r\n                      style={{\r\n                        background: `url(${blog.featuredImage})`,\r\n                        backgroundPosition: \"center\",\r\n                        backgroundSize: \"cover\",\r\n                      }}\r\n                    ></div>\r\n                  </div>\r\n\r\n                  <div\r\n                    style={{\r\n                      color: \"#ff7700\",\r\n                      textAlign: \"right\",\r\n                      textTransform: \"uppercase\",\r\n                    }}\r\n                  >\r\n                    {blog?.category?.name}\r\n                  </div>\r\n                  <h2\r\n                    style={{ fontWeight: \"600\" }}\r\n                    className=\"font-subheading-black\"\r\n                  >\r\n                    {blog.title}\r\n                  </h2>\r\n                  <p className=\"font-paragraph-black\">\r\n                    {\" \"}\r\n                    {/* {ReactHtmlParser(blog?.paragraph)} */}\r\n                  </p>\r\n                </Link>\r\n              )\r\n          )}\r\n        </div>\r\n      </div>\r\n      {/* 8th row */}\r\n      {/* 9th row */}\r\n      <div className=\"home-row-9\">\r\n        <h1\r\n          style={{ color: \"#fff\", fontSize: \"4rem\" }}\r\n          className=\"font-heading-white\"\r\n        >\r\n          <T>footer.community</T>\r\n        </h1>\r\n        <h2\r\n          style={{ color: \"#fff\", fontSize: \"2.5rem\" }}\r\n          className=\"font-subheading-white\"\r\n        >\r\n          <T>footer.follow</T>\r\n        </h2>\r\n      </div>\r\n      {/* 9th row */}\r\n      <Footer />\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default withRouter(Home);\r\n","C:\\Users\\ammar.masood\\Desktop\\Claude_Practice\\realchallenge-frontend-v2\\src\\pages\\Trainers.js",["873","874","875","876"],"import React, { useState, useEffect } from \"react\";\r\nimport \"../assets/home.css\";\r\nimport \"../assets/trainers.css\";\r\nimport Navbar from \"../components/Navbar\";\r\nimport Footer from \"../components/Footer\";\r\nimport { Link } from \"react-router-dom\";\r\nimport { Input, Collapse } from \"antd\";\r\nimport { ArrowRightOutlined, SearchOutlined } from \"@ant-design/icons\";\r\n\r\nimport ChallengeCard from \"../components/Cards/ChallengeCard\";\r\nimport { getAllTrainers } from \"../services/trainers\";\r\nimport slug from \"elegant-slug\";\r\nimport { T } from \"../components/Translate\";\r\n\r\nconst { Panel } = Collapse;\r\n\r\nconst filterTextStyle = {\r\n  margin: 0,\r\n  padding: 0,\r\n  cursor: \"pointer\",\r\n  fontSize: \"16px\",\r\n  padding: \"5px 12px\",\r\n  marginRight: \"10px\",\r\n};\r\n\r\nfunction Trainers() {\r\n  const [name, setName] = useState(\"\");\r\n\r\n  // eslint-disable-next-line\r\n  const [allTrainers, setAllTrainers] = useState([]);\r\n  const [filterTrainers, setFilterTrainers] = useState([]);\r\n  const [searchText, setSearchText] = useState(\"\");\r\n  const [filterGender, setFilterGender] = useState(\"\");\r\n\r\n  useEffect(() => {\r\n    // setFilterTrainers(allTrainers);\r\n    fetchData();\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    const g = allTrainers.filter((trainer) => trainer.gender === filterGender);\r\n    setFilterTrainers(g.length ? g : allTrainers);\r\n  }, [filterGender]);\r\n\r\n  const fetchData = async () => {\r\n    const data = await getAllTrainers();\r\n    // console.log(data);\r\n    setAllTrainers(data.trainers);\r\n    setFilterTrainers(data.trainers);\r\n    // setRecommandedChallenges(data.challenges);\r\n  };\r\n\r\n  return (\r\n    <div>\r\n      <Navbar />\r\n      {/* <Hero /> */}\r\n      <div className=\"page-header\">\r\n        <div className=\"page-header-textbox\">\r\n          <h1 className=\"font-heading-white\">\r\n            {\" \"}\r\n            <T>trainers.skill</T>\r\n          </h1>\r\n          <p className=\"font-paragraph-white\">\r\n            {\" \"}\r\n            <T>trainers.let_us</T>\r\n          </p>\r\n        </div>\r\n      </div>\r\n      {/* 2nd row */}\r\n      <div style={{ backgroundColor: \"#222932\" }}>\r\n        <div className=\"trainers-2-row\">\r\n          <p className=\"font-paragraph-white\">\r\n            <T>trainers.real_challenge_coach</T>\r\n          </p>\r\n        </div>\r\n      </div>\r\n      {/* trainers */}\r\n      <div style={{ backgroundColor: \"#171e27\" }}>\r\n        <div className=\"trainers-3-row\">\r\n          <Input\r\n            size=\"large\"\r\n            placeholder=\"Search Trainers By Name\"\r\n            style={{\r\n              // backgroundColor: \"transparent\",\r\n              padding: \"20px\",\r\n              color: \"#fff\",\r\n              fontSize: \"2rem\",\r\n              opacity: \"0.8\",\r\n            }}\r\n            value={searchText}\r\n            onChange={(e) => {\r\n              setSearchText(e.target.value);\r\n              setFilterTrainers(\r\n                allTrainers.filter((trainer) =>\r\n                  trainer.username\r\n                    .toUpperCase()\r\n                    .includes(e.target.value.toUpperCase())\r\n                )\r\n              );\r\n            }}\r\n            prefix={<SearchOutlined />}\r\n          />\r\n          <Collapse ghost>\r\n            <Panel\r\n              showArrow={false}\r\n              header={\r\n                <p\r\n                  className=\"font-paragraph-white\"\r\n                  style={{\r\n                    margin: 0,\r\n                    padding: 0,\r\n                    fontSize: \"18px\",\r\n                  }}\r\n                >\r\n                  <T>trainers.filter_trainer</T>\r\n                </p>\r\n              }\r\n              key=\"1\"\r\n            >\r\n              <p className=\"font-paragraph-white\">\r\n                <T>trainers.filter_gender</T>\r\n              </p>\r\n              <div style={{ display: \"flex\" }}>\r\n                <p\r\n                  className=\"font-paragraph-white\"\r\n                  onClick={() =>\r\n                    filterGender === \"male\"\r\n                      ? setFilterGender(\"\")\r\n                      : setFilterGender(\"male\")\r\n                  }\r\n                  style={{\r\n                    ...filterTextStyle,\r\n                    backgroundColor:\r\n                      filterGender === \"male\" ? \"#ff7700\" : \"#454b52\",\r\n                  }}\r\n                >\r\n                  <T>trainers.male</T>\r\n                </p>\r\n                <p\r\n                  className=\"font-paragraph-white\"\r\n                  onClick={() =>\r\n                    filterGender === \"female\"\r\n                      ? setFilterGender(\"\")\r\n                      : setFilterGender(\"female\")\r\n                  }\r\n                  style={{\r\n                    ...filterTextStyle,\r\n                    backgroundColor:\r\n                      filterGender === \"female\" ? \"#ff7700\" : \"#454b52\",\r\n                  }}\r\n                >\r\n                  <T>trainers.female</T>\r\n                </p>\r\n                <p\r\n                  className=\"font-paragraph-white\"\r\n                  onClick={() =>\r\n                    filterGender === \"other\"\r\n                      ? setFilterGender(\"\")\r\n                      : setFilterGender(\"other\")\r\n                  }\r\n                  style={{\r\n                    ...filterTextStyle,\r\n                    backgroundColor:\r\n                      filterGender === \"other\" ? \"#ff7700\" : \"#454b52\",\r\n                  }}\r\n                >\r\n                  <T>trainers.other</T>\r\n                </p>\r\n              </div>\r\n            </Panel>\r\n          </Collapse>\r\n          <div className=\"trainers-3-row-cards\">\r\n            {filterTrainers.map((trainer) => (\r\n              <Link to={`/creator/${slug(trainer.username)}/${trainer._id}`}>\r\n                <ChallengeCard\r\n                  picture={trainer.avatarLink ? `${trainer.avatarLink}` : \"\"}\r\n                  // rating={5}\r\n                  name={trainer.username}\r\n                  // location={trainer.location}\r\n                  newc={false}\r\n                />\r\n              </Link>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </div>\r\n      {/* 3th row */}\r\n      <div className=\"home-row-7 background-trainers\">\r\n        <div className=\"home-row-7-container\" style={{ minHeight: \"350px\" }}>\r\n          <div className=\"home-row-7-container-text\">\r\n            <h2 style={{ fontSize: \"2rem\" }} className=\"font-subheading-black\">\r\n              <T>trainers.need_more</T>\r\n            </h2>\r\n            <h1 style={{ fontSize: \"4.5rem\" }} className=\"font-heading-black\">\r\n              <T>trainers.feel_better</T>\r\n            </h1>\r\n            <p\r\n              style={{ fontSize: \"1.8rem\", paddingBottom: \"10px\" }}\r\n              className=\"font-paragraph-black\"\r\n            >\r\n              <T>trainers.become</T>\r\n            </p>\r\n            <Link className=\"home-button\" to=\"/how-it-works\">\r\n              <span className=\"home-button-text font-paragraph-white\">\r\n                <T>trainers.inspire</T>\r\n                <ArrowRightOutlined />\r\n              </span>\r\n            </Link>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      {/* 7th row */}\r\n\r\n      <Footer />\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Trainers;\r\n","C:\\Users\\ammar.masood\\Desktop\\Claude_Practice\\realchallenge-frontend-v2\\src\\pages\\Pricing.js",["877"],"import React, { useState } from \"react\";\r\nimport \"../assets/home.css\";\r\nimport \"../assets/trainers.css\";\r\nimport \"../assets/pricing.css\";\r\nimport Navbar from \"../components/Navbar\";\r\nimport Footer from \"../components/Footer\";\r\n// import { Link } from \"react-router-dom\";\r\n// import {\r\n//   ArrowRightOutlined,\r\n//   CheckOutlined,\r\n//   EuroOutlined,\r\n//   DoubleRightOutlined,\r\n//   PlayCircleOutlined,\r\n// } from \"@ant-design/icons\";\r\n// import ModalVideo from \"react-modal-video\";\r\n\r\nimport NewWelcome from \"./NewWelcome\";\r\n// import \"react-modal-video/scss/modal-video.scss\";\r\nfunction Pricing() {\r\n  // const [isOpen, setIsOpen] = useState(false);\r\n\r\n  return (\r\n    <div>\r\n      <Navbar />\r\n      <NewWelcome onPricingPage={true} />\r\n      {/* video modal */}\r\n      {/* <ModalVideo\r\n        channel=\"youtube\"\r\n        autoplay\r\n        isOpen={isOpen}\r\n        videoId=\"https://youtu.be/HMApf8yWUtg\"\r\n        onClose={() => setIsOpen(false)}\r\n      />\r\n      <div className=\"pricing-row-1\">\r\n        <h1 className=\"font-heading-white\">{t(\"pricing.great\")}</h1>\r\n        <h2 className=\"font-subheading-white\">{t(\"pricing.p\")}</h2>\r\n        <div className=\"pricing-row-1-cards-containers\"> */}\r\n      {/* card 1 */}\r\n      {/* <div className=\"two-cards\">\r\n            <div className=\"pricing-row-1-card\">\r\n              <h1 className=\"font-subheading-black\"> {t(\"pricing.c3\")}</h1>\r\n              <div className=\"home-row-2-col-2-box\">\r\n                <CheckOutlined\r\n                  style={{\r\n                    color: \"#ff7700\",\r\n                    fontSize: \"2.5rem\",\r\n                    paddingRight: \"0.5rem\",\r\n                  }}\r\n                />\r\n                <span className=\"home-text font-paragraph-black\">\r\n                  {t(\"pricing.c3_months\")}\r\n                </span>\r\n              </div>\r\n              <div className=\"home-row-2-col-2-box\">\r\n                <CheckOutlined\r\n                  style={{\r\n                    color: \"#ff7700\",\r\n                    fontSize: \"2.5rem\",\r\n                    paddingRight: \"0.5rem\",\r\n                  }}\r\n                />\r\n                <span className=\"home-text font-paragraph-black\">\r\n                  {t(\"pricing.save\")} 20%\r\n                </span>\r\n              </div>\r\n              <div className=\"pricing-card-price \">\r\n                <h1 className=\"font-heading-black\">€6 / {t(\"pricing.week\")}</h1>\r\n                <p className=\"font-subheading-black\">\r\n                  {t(\"pricing.c3_billed\")}\r\n                </p>\r\n              </div>\r\n            </div> */}\r\n      {/* card 2 */}\r\n      {/* <div className=\"pricing-row-1-card most-popular-card\">\r\n              <div className=\"most-popular-tag\">{t(\"pricing.most\")}</div>\r\n              <h1 className=\"font-subheading-black\">{t(\"pricing.c12\")}</h1>\r\n              <div className=\"home-row-2-col-2-box\">\r\n                <CheckOutlined\r\n                  style={{\r\n                    color: \"#ff7700\",\r\n                    fontSize: \"2.5rem\",\r\n                    paddingRight: \"0.5rem\",\r\n                  }}\r\n                />\r\n                <span className=\"home-text font-paragraph-black\">\r\n                  {t(\"pricing.c12_months\")}\r\n                </span>\r\n              </div>\r\n              <div className=\"home-row-2-col-2-box\">\r\n                <CheckOutlined\r\n                  style={{\r\n                    color: \"#ff7700\",\r\n                    fontSize: \"2.5rem\",\r\n                    paddingRight: \"0.5rem\",\r\n                  }}\r\n                />\r\n  